generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTH & USER
// ============================================

model User {
  id                 String     @id @default(cuid())
  name               String?
  email              String?    @unique
  emailVerified      DateTime?
  image              String?
  password           String?    // hashed, only set for email/password accounts
  plan               String     @default("free") // "free" | "starter" | "pro"
  stripeCustomerId   String?
  stripeSubId        String?
  onboardingComplete Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  accounts   Account[]
  sessions   Session[]
  businesses Business[]
  strategies Strategy[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// BUSINESS & STRATEGY
// ============================================

model Business {
  id             String     @id @default(cuid())
  userId         String
  businessName   String
  industry       String
  description    String     @db.Text
  website        String?
  targetAudience String     @db.Text // JSON string of audience details
  platforms      String[]
  goals          String[]
  duration       Int        @default(30)
  contentTone    String[]
  availableAssets String[]
  budget             String?
  plannedStartDate   String?
  pastPerformance    String?    @db.Text
  assetDescription   String?    @db.Text
  createdAt          DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategies Strategy[]

  @@index([userId])
}

model Strategy {
  id               String         @id @default(cuid())
  userId           String
  businessId       String
  status           String         @default("generating") // "generating" | "ready" | "failed"
  overview         Json?
  audiencePersona  Json?
  platformStrategy Json?
  contentPillars   Json?
  calendar         Json?
  generationStep   Int            @default(0)
  startDate        DateTime       @default(now())
  projectStatus    String         @default("active") // "active" | "paused" | "archived"
  projectColor     String         @default("#C9A7EB") // user-chosen color for categorization
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  briefs   ContentBrief[]

  @@index([userId])
  @@index([businessId])
}

model ContentBrief {
  id                 String   @id @default(cuid())
  strategyId         String
  dayNumber          Int
  platform           String
  pillar             String
  goal               String
  hook               String   @db.Text
  script             String   @db.Text
  visualDirection    String   @db.Text
  caption            String   @db.Text
  hashtags           String[]
  cta                String
  postingTime            String
  postingTimeRationale   String?  @db.Text
  strategicReasoning     String   @db.Text
  contentFormat      String   @default("Single Image Post")  // "Reel (15-30s)", "Carousel Post (3 slides)", etc.
  aiMediaPrompt      String?  @db.Text                       // AI prompt for generating visuals
  carouselSlides     Json?                                    // [{slideNumber, textOverlay, visualDescription}]
  postStatus         String   @default("pending") // "pending" | "completed" | "skipped"
  createdAt          DateTime @default(now())

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  feedback BriefFeedback[]

  @@index([strategyId])
  @@index([strategyId, dayNumber])
}

model BriefFeedback {
  id        String   @id @default(cuid())
  briefId   String
  userId    String
  content   String   @db.Text
  type      String   @default("note") // "note" | "ai_suggestion"
  createdAt DateTime @default(now())

  brief ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)

  @@index([briefId])
}

model PerformanceLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
}
